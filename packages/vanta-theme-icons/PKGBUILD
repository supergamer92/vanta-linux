# Maintainer: Vanta Linux Team

pkgname=vanta-theme-icons
pkgver=1.0
pkgrel=1
pkgdesc="Vanta Linux - Icon theme base (uses Breeze as runtime fallback)"
arch=('any')
url="https://vanta.linux"
license=('GPL3')
depends=('breeze-icons')
source=("index.theme")
sha256sums=('SKIP')

package() {
  install -d "${pkgdir}/usr/share/icons/Vanta"
  install -Dm644 index.theme "${pkgdir}/usr/share/icons/Vanta/index.theme"
}
