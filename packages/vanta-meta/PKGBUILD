# Maintainer: Vanta Linux Team
# vanta-meta: metapackage pulling in the complete Vanta Linux experience.
# Installs the base system, all Vanta theme packages, and default applications.
#
# This package contains no files of its own. It exists so that
#   pacman -S vanta-meta
# installs everything needed for a functioning Vanta system.

pkgname=vanta-meta
pkgver=1.0
pkgrel=1
pkgdesc="Vanta Linux - metapackage for the complete Vanta desktop experience"
arch=('x86_64')
url="https://vanta.linux"
license=('GPL3')
depends=(
  # ==== Base system ====
  'linux'
  'linux-firmware'
  'amd-ucode'
  'mesa'
  'nvidia-dkms'
  'nvidia-utils'
  'nvidia-settings'
  'pipewire'
  'pipewire-pulse'
  'pipewire-alsa'
  'wireplumber'
  'networkmanager'
  'bluez'
  'bluez-utils'

  # ==== Display / Compositor ====
  'plasma-meta'
  'kwin'
  'wayland'
  'xorg-xwayland'
  'sddm'

  # ==== Core applications ====
  'dolphin'
  'konsole'
  'kate'
  'spectacle'
  'gwenview'
  'ark'
  'kcalc'
  'kwrite'
  'elisa'
  'firefox'
  'mpv'

  # ==== Fonts ====
  'vanta-fonts'

  # ==== Theming ====
  'vanta-theme-plasma'
  'vanta-theme-kwin'
  'vanta-theme-icons'
  'vanta-theme-cursors'
  'vanta-theme-sounds'
  'vanta-theme-sddm'
  'vanta-theme-plymouth'
  'vanta-theme-grub'

  # ==== System tooling ====
  'vanta-settings'
  'vanta-updater'
  'vanta-installer'
  'snapper'
  'grub-btrfs'
  'inotify-tools'
  'flatpak'
  'fwupd'

  # ==== Developer tooling ====
  'git'
  'base-devel'
)
optdepends=(
  'pamac: graphical package manager'
  'celluloid: video player (GTK)'
  'calamares: system installer'
)
options=('!strip' '!purge' '!zipman')
install=vanta-meta.install

package() {
  # metapackage — all work done by depends
  return 0
}
