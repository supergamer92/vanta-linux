WindowsBlockCompositing=false
AnimationSpeed=1.5
AnimationCurve=linear
XRenderSmoothScale=false
GlSmoothScale=2
UnredirectFullscreen=true
HiddenPreviews=1

[Effect-Slide]
SlideInDuration=200
SlideOutDuration=200

[Effect-Fade]
FadeInDuration=150
FadeOutDuration=150

[Effect-Scale]
ScaleInDuration=200
ScaleOutDuration=200

[Effect-DesaturateUnresponsive]
